{
  "name": "lisichkinx",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @lisichkinx/web",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspace @lisichkinx/web",
    "storybook": "npm run storybook --workspace @lisichkinx/web",
    "build-storybook": "npm run build-storybook --workspace @lisichkinx/web",
    "test": "npm run test --workspace @lisichkinx/web",
    "test:e2e": "npm run test:e2e --workspace @lisichkinx/web",
    "test:e2e:ui": "npm run test:e2e:ui --workspace @lisichkinx/web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "stylelint": "stylelint \"apps/**/*.{css,scss}\"",
    "stylelint:fix": "stylelint \"apps/**/*.{css,scss}\" --fix",
    "type-check": "tsc --noEmit --project apps/web/tsconfig.json",
    "deps-cruise": "depcruise --config dependency-cruiser.config.cjs apps/web/app apps/web/i18n apps/web/proxy.ts apps/web/shared apps/web/widgets apps/web/views",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "npm run type-check && npm run lint && npm run stylelint && npm run test && npm run deps-cruise && npm run format:check",
    "fix": "npm run lint:fix && npm run stylelint:fix && npm run format",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md,mdx,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "postcss": "8.5.12"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-better-tailwindcss": "^4.4.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "stylelint": "^17.9.1",
    "stylelint-config-css-modules": "^4.6.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3"
  }
}
